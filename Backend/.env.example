# ============================================================
# AI Research Assistant — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# App
APP_NAME="AI Research Assistant"
DEBUG=false
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────
# SQLite (default — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./rag_v2.db

# PostgreSQL (uncomment when ready):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_db

# ── JWT / Auth ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION_USE_256BIT_RANDOM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=15

# ── File Upload ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads
VECTOR_DIR=vector_store

# ── Redis (optional) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false       # Set true when Redis is running

# ── Celery (optional) ────────────────────────────────────────
CELERY_ENABLED=false      # Set true when Celery workers are running
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Ollama / LLM ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=phi3
EMBED_MODEL=nomic-embed-text

# ── Web Search (optional) ────────────────────────────────────
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_FAIL_OPEN=true

# ── Email (for password reset) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ai-research.app
FRONTEND_URL=http://localhost:5173
