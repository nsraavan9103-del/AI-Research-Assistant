# ============================================================
# AI Research Assistant — .env (Backend)
# IMPORTANT: Add this file to .gitignore — never commit secrets!
# ============================================================

# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-real-64-char-random-secret-key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Ollama model settings (phi3 recommended for your GTX 1650Ti + 8GB RAM)
# Alternatives: gemma2:2b (better QA), tinyllama (fastest)
OLLAMA_MODEL=phi3
EMBED_MODEL=nomic-embed-text
